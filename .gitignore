# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# Vendored third-party source trees are local-only in this repo.
/vendor/
**/vendor/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Local docs and binding test outputs
site/
.venv-mkdocs/
tests/bindings/dotnet/**/bin/
tests/bindings/dotnet/**/obj/
tests/bindings/node/*.node
tests/bindings/**/bin/
tests/bindings/**/obj/
tests/bindings/**/build/
tests/bindings/**/dist/
tests/bindings/**/out/
tests/bindings/**/target/
tests/bindings/**/node_modules/
tests/bindings/**/.dart_tool/
tests/bindings/**/.pub/
tests/bindings/**/.pub-cache/
tests/bindings/**/.venv/
tests/bindings/**/.pytest_cache/
tests/bindings/**/.mypy_cache/
tests/bindings/**/.ruff_cache/
tests/bindings/**/__pycache__/
tests/bindings/**/*.class
tests/bindings/**/*.dll
tests/bindings/**/*.dylib
tests/bindings/**/*.exe
tests/bindings/**/*.lib
tests/bindings/**/*.so
tests/bindings/**/*.a
tests/bindings/**/*.node

# Packaged language bindings live under /bindings; keep source, ignore build artifacts.
/bindings/**/build/
/bindings/**/dist/
/bindings/**/out/
/bindings/**/target/
/bindings/**/node_modules/
/bindings/**/.dart_tool/
/bindings/**/.pub/
/bindings/**/.pub-cache/
/bindings/**/.venv/
/bindings/**/.pytest_cache/
/bindings/**/.mypy_cache/
/bindings/**/.ruff_cache/
/bindings/**/__pycache__/
/bindings/**/bin/
/bindings/**/obj/
/bindings/**/*.class
/bindings/**/*.dll
/bindings/**/*.dylib
/bindings/**/*.exe
/bindings/**/*.lib
/bindings/**/*.so
/bindings/**/*.a
/bindings/**/*.node

# Benchmark runner output artifacts
/benchmarks/python_embedded_compare/out/*
!/benchmarks/python_embedded_compare/out/.gitkeep
/benchmarks/python_embedded_compare/helpers/**/bin/
/benchmarks/python_embedded_compare/helpers/**/obj/
/benchmarks/python_embedded_compare/**/__pycache__/
/benchmarks/python_embedded_compare/**/*.pyc
/build/bench*/runs/
/build/bench*/compares/

# Local DecentDB database artifacts
*.ddb
*.ddb.wal
*.db 
*.db.wal
# Allow migration test fixtures (binary .db files needed by CI)
!crates/decentdb-migrate/tests/fixtures/*.db
*.log
/.tmp/

bindings/dart/examples/console_complex/*.json
*.pyc
